{
  "name": "pi-goal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pi extension that keeps a visible main session working until an independent verifier accepts the goal.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "goal"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "check": "npm run typecheck && npm test",
    "compare:rpc": "node scripts/run-rpc-comparison.mjs",
    "pi:qwen": "scripts/pi-goal-qwen",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "typebox": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
